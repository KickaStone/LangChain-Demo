# Copy to project root: cp .env.example .env

# Select a built-in provider preset
# openai | deepseek | moonshot | zhipu | dashscope | siliconflow | groq | together | openrouter | ollama
LLM_PROVIDER=openai

# API keys — set the one matching your provider
OPENAI_API_KEY=sk-your-api-key-here
# DEEPSEEK_API_KEY=
# MOONSHOT_API_KEY=
# ZHIPU_API_KEY=
# DASHSCOPE_API_KEY=
# SILICONFLOW_API_KEY=
# GROQ_API_KEY=
# TOGETHER_API_KEY=
# OPENROUTER_API_KEY=

# Optional overrides (unset to use provider defaults)
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_MODELS=gpt-4o-mini,gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_TEMPERATURE=0.7

# LangGraph Studio / LangSmith (required for `langgraph dev`)
# LANGSMITH_API_KEY=lsv2_pt_...
# LANGSMITH_PROJECT=llm-demos
# LANGSMITH_TRACING=true

# Set to false to avoid uploading traces to LangSmith cloud
# LANGSMITH_TRACING=false